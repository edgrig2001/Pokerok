# ===== ИГРА =====
def start_game(user_id):
    d = deck()
    games[user_id] = {
        "deck": d,
        "player": [d.pop(), d.pop()],
        "bots": [[d.pop(), d.pop()] for _ in range(3)],
        "table": [],
        "stage": "preflop",
        "bet": 0
    }

def next_stage(game):
    if game["stage"] == "preflop":
        game["table"] = [game["deck"].pop() for _ in range(3)]
        game["stage"] = "flop"
    elif game["stage"] == "flop":
        game["table"].append(game["deck"].pop())
        game["stage"] = "turn"
    elif game["stage"] == "turn":
        game["table"].append(game["deck"].pop())
        game["stage"] = "river"
    else:
        return True
    return False

