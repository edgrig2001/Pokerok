            edit(chat_id, msg_id, text, keyboard())

        elif user_id in games:
            game = games[user_id]

            if action == "fold":
                update_balance(user_id, -50)
                edit(chat_id, msg_id, "❌ Ты сбросил (-50)")
                del games[user_id]
                return "ok"

            if "bet" in action:
                game["bet"] += int(action.replace("bet",""))

            if action == "allin":
                game["bet"] += get_balance(user_id)

            # боты
            for b in game["bots"]:
                s = strength(b, game["table"])
                # просто логика

            finished = next_stage(game)

            if finished:
                player = strength(game["player"], game["table"])
                bots = max([strength(b, game["table"]) for b in game["bots"]])

                if player > bots:
                    update_balance(user_id, 100)
                    result = "🎉 Победа"
